# Google API key for Gemini API access
# Get your key from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_api_key_here

# Optional: request timeout in milliseconds (default: 30000)
ASK_GOOGLE_TIMEOUT_MS=30000

# Optional: auto-routing between Gemini tiers (default: on).
# ASK_GOOGLE_ROUTER_ENABLED=true
# ASK_GOOGLE_ROUTER_MODEL=flash-lite
# ASK_GOOGLE_ROUTER_TIMEOUT_MS=5000
# ASK_GOOGLE_ROUTER_FALLBACK_MODEL=flash

# Optional: override model ids if Google renames preview models.
# ASK_GOOGLE_MODEL_FLASH=gemini-3.5-flash
# ASK_GOOGLE_MODEL_FLASH_LITE=gemini-3.1-flash-lite

# Optional: restrict which model aliases are exposed to the tool (default: all enabled).
# Comma-separated; valid values: flash, flash-lite.
# Unknown aliases are ignored with a warning; if none are valid the server exits on startup.
# (The legacy value "pro" is still accepted on tool calls and routes to flash.)
# ASK_GOOGLE_ENABLED_MODELS=flash,flash-lite

# Optional: Gemini 3 thinking level per model. Uppercase values.
# flash and flash-lite accept: MINIMAL|LOW|MEDIUM|HIGH.
# Both default to the SDK default (light thinking).
# ASK_GOOGLE_THINKING_LEVEL_FLASH=MINIMAL
# ASK_GOOGLE_THINKING_LEVEL_FLASH_LITE=MINIMAL
