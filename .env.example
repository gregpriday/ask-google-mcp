# Google API Key for Gemini API access
# Get your key from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_api_key_here

# Gemini Model (optional)
# Default: models/gemini-flash-latest (cost-efficient, points to Gemini 2.5 Flash)
# Options:
#   - models/gemini-flash-latest (default, cost-efficient)
#   - models/gemini-2.5-flash (stable Gemini 2.5 Flash)
#   - models/gemini-2.5-pro-latest (more powerful, higher cost)
# GEMINI_MODEL=models/gemini-flash-latest
