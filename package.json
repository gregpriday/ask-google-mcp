{
  "name": "@gpriday/ask-google-mcp",
  "version": "0.3.0",
  "description": "A Model Context Protocol (MCP) server that provides AI-powered Google search using Gemini with search grounding",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "ask-google-mcp": "src/index.js"
  },
  "files": [
    "src/",
    "scripts/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    ".env.example"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gpriday/ask-google-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/gpriday/ask-google-mcp/issues"
  },
  "homepage": "https://github.com/gpriday/ask-google-mcp#readme",
  "scripts": {
    "start": "node src/index.js",
    "test": "node --test test/unit/**/*.test.js",
    "test:integration": "node test/test-gemini-mcp.js",
    "test:all": "npm test && npm run test:integration",
    "dev": "node --watch src/index.js",
    "check-env": "node scripts/check-env.js",
    "security:audit": "npm audit",
    "security:fix": "npm audit fix",
    "security:update": "npm update && npm audit",
    "prestart": "npm run check-env"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "gemini",
    "google",
    "search",
    "ai",
    "llm",
    "claude"
  ],
  "author": "Greg Priday <greg@siteorigin.com>",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "dotenv": "^16.6.1"
  }
}
