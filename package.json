{
  "name": "ask-google-mcp",
  "version": "1.0.0",
  "description": "A Model Context Protocol (MCP) server that provides AI-powered Google search using Gemini 2.5 Pro with search grounding",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "ask-google-mcp": "./src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "test": "node test/test-gemini-mcp.js",
    "dev": "node --watch src/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "gemini",
    "google",
    "search",
    "ai",
    "llm",
    "claude"
